<!DOCTYPE html>
<html>
<head>
  <title>Editar Produto</title>
</head>
<body>

  <h1>Editar Produto</h1>

  <form action="/products/update/<%= product.id %>" method="POST">
    <input type="text" name="name" placeholder="Nome do Produto" value="<%= product.name %>" required>
    <input type="number" step="0.01" placeholder="Custo"name="cost" value="<%= product.cost %>" required>
    <input type="number" step="0.01" placeholder="Preço de Venda" name="price" value="<%= product.price %>" required>
    <input type="number" name="stock" placeholder="Estoque" value="<%= product.stock %>" required>

    <button type="submit">Atualizar</button>
  </form>

  <br>
  <a href="/products">Voltar</a>

</body>
</html>
